# ===== Sukhon Arena — ตัวอย่างค่า environment =====
# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง (ห้าม commit .env)

# ----- PostgreSQL -----
# docker compose ใช้ค่าเหล่านี้ทั้งตอนตั้ง container "db" และตอนที่ app ต่อเข้า DB
# ⚠️ เปลี่ยน POSTGRES_PASSWORD เป็นค่าสุ่มยาว ๆ ก่อนใช้จริง
POSTGRES_USER=
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=arena

# ต่อ DB ตอน dev (รูปแบบ: postgres://<user>:<pass>@<host>:<port>/<db>)
# เมื่อรันด้วย docker compose ค่านี้ถูก override ให้ชี้ service "db" อยู่แล้ว
DATABASE_URL=postgres://arena:CHANGE_ME@localhost:5017/arena

# JWT — สุ่มค่ายาว ๆ เช่น `openssl rand -hex 32`
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ตั้ง true เฉพาะเมื่อเสิร์ฟผ่าน HTTPS ไม่งั้นเบราว์เซอร์จะทิ้ง session cookie
COOKIE_SECURE=false

# ----- SchoolOS Public API (host ใหม่) -----
# base = http://<host>:3002 (ไม่ต้องมี /api/public/v1 — client เติมให้เอง)
SCHOOLOS_API_BASE=http://192.168.200.56:3002
# key เดียว หลาย scope: ต้องมี students:read, teachers:read, auth:students, auth:teachers
SCHOOLOS_API_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# Seed admin local (เปลี่ยนรหัสหลัง deploy จริง)
SEED_ADMIN_USERNAME=
SEED_ADMIN_PASSWORD=

PORT=3017
