# ===== Sukhon Arena — ตัวอย่างค่า environment =====
# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง (ห้าม commit .env)

# ----- PostgreSQL -----
# arena ไม่สร้าง container db เอง — ไปเกาะ postgres-core ที่มีอยู่แล้วบน network "school-net"
# docker compose เอาค่าเหล่านี้ไปประกอบเป็น DATABASE_URL ของ app
ARENA_DB_HOST=postgres-core
ARENA_DB_PORT=5432
ARENA_DB_USER=arena
ARENA_DB_PASSWORD=CHANGE_ME
ARENA_DB_NAME=arena

# ต่อ DB ตอน dev บน host (รูปแบบ: postgres://<user>:<pass>@<host>:<port>/<db>)
# เมื่อรันด้วย docker compose ค่านี้ถูก override ให้ชี้ postgres-core:5432 อยู่แล้ว
DATABASE_URL=postgres://arena:CHANGE_ME@localhost:5432/arena

# JWT — สุ่มค่ายาว ๆ เช่น `openssl rand -hex 32`
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ตั้ง true เฉพาะเมื่อเสิร์ฟผ่าน HTTPS ไม่งั้นเบราว์เซอร์จะทิ้ง session cookie
COOKIE_SECURE=false

# subpath ที่เสิร์ฟ (basePath ของ Next) — ถูก bake ตอน `next build` แก้แล้วต้อง build ใหม่
# ค่าว่าง = เสิร์ฟที่ root (เหมาะกับ dev) ; prod หลัง reverse proxy ตั้ง /arena
# หมายเหตุ: docker compose มี default /arena ให้อยู่แล้วถ้าไม่ได้ตั้งตัวแปรนี้เลย
BASE_PATH=

# ----- SchoolOS Public API -----
# base = http://<host>:3002 (ไม่ต้องมี /api/public/v1 — client เติมให้เอง)
SCHOOLOS_API_BASE=http://192.168.200.56:3002
# key เดียว หลาย scope: ต้องมี students:read, teachers:read, auth:students, auth:teachers
SCHOOLOS_API_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# ----- Auto-bootstrap (รันอัตโนมัติตอนคอนเทนเนอร์สตาร์ท) -----
# ไม่มีการสร้าง admin แล้ว — สิทธิ์ admin มาจาก role "teacher-admin" ของ SchoolOS โดยตรง
# ครูที่ SchoolOS กำหนดเป็น teacher-admin จะล็อกอินเข้าเป็น admin ของระบบนี้เอง
# (มอบ admin/recorder เพิ่มแบบมือได้ที่หน้า /admin/teachers)
# ปีการศึกษาตั้งต้น (พ.ศ.) — ใช้เฉพาะตอน DB ยังไม่มีปีใดเลย ; เว้นว่าง = ปีปัจจุบัน
BOOTSTRAP_YEAR_BE=
# ตั้ง 1 เพื่อปิด auto-bootstrap ทั้งหมด (ข้ามการสร้างปีการศึกษาตั้งต้น)
SKIP_BOOTSTRAP=

# ----- admin local สำหรับ dev เท่านั้น (optional) -----
# ใช้โดย `npm run db:seed` เพื่อสร้าง admin local ไว้ทดสอบตอน dev — prod ไม่ใช้
# ไม่ตั้งก็ได้ (default: admin / admin1234) ; ถ้าค่ามี # ต้องครอบด้วย "..."
#SEED_ADMIN_USERNAME=admin
#SEED_ADMIN_PASSWORD="CHANGE_ME"

PORT=3017
##