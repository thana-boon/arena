# ===== SKDW Arena — ตัวอย่างค่า environment =====
# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง (ห้าม commit .env)

# Database (XAMPP MariaDB/MySQL) — สร้าง database ชื่อ compete + user แยก (อย่าใช้ root)
DATABASE_URL=mysql://compete_user:CHANGE_ME@localhost:3306/compete

# JWT — สุ่มค่ายาว ๆ เช่น `openssl rand -hex 32`
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ตั้ง true เฉพาะเมื่อเสิร์ฟผ่าน HTTPS ไม่งั้นเบราว์เซอร์จะทิ้ง session cookie (login วนกลับหน้าเดิม)
COOKIE_SECURE=false

# Teacher API
TEACHER_API_BASE=http://192.168.200.9/teacher-api
TEACHER_API_KEY=tta_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Student API (2 keys แยก scope)
STUDENT_API_BASE=http://192.168.200.9/students-api/v1
STUDENT_API_KEY_VERIFY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STUDENT_API_KEY_READ=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Seed admin local (เปลี่ยนรหัสหลัง deploy จริง)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin1234

PORT=5005
