{
  "name": "skdw-arena",
  "version": "1.0.0",
  "private": true,
  "description": "Sukhon Arena - ระบบจัดการการแข่งขันทางวิชาการ โรงเรียนสุคนธีรวิทย์",
  "scripts": {
    "dev": "next dev -p 3017",
    "build": "next build",
    "start": "next start -p 3017",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push --force",
    "db:seed": "tsx src/db/seed.ts",
    "db:bootstrap": "tsx src/db/bootstrap.ts",
    "admin:password": "tsx src/db/set-admin-password.ts",
    "db:setup": "npm run db:push && npm run db:seed"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "drizzle-orm": "0.38.3",
    "jose": "5.9.6",
    "next": "15.1.6",
    "pg": "8.13.1",
    "qrcode": "^1.5.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "dotenv": "16.4.7",
    "drizzle-kit": "0.30.1",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
