    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "@types/bcryptjs": "2.4.6",
    "typescript": "5.7.3",
    "drizzle-kit": "0.30.1",
    "tsx": "4.19.2",
    "dotenv": "16.4.7"
  }
